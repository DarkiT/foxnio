# FoxNIO Configuration Example
# Copy this file to .env and configure your settings

# =============================================================================
# ENCRYPTION SETTINGS
# =============================================================================

# Master encryption key for sensitive data (API Keys, OAuth tokens, TOTP secrets)
# Generate with: openssl rand -base64 32
# WARNING: Never commit this key to source control!
FOXNIO_MASTER_KEY=

# For key rotation, use format: new_key:old_key
# FOXNIO_MASTER_KEY=new_base64_key:old_base64_key

# =============================================================================
# SERVER SETTINGS
# =============================================================================

# Server host and port
HOST=0.0.0.0
PORT=3000

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

# PostgreSQL connection URL
DATABASE_URL=postgres://foxnio:password@localhost:5432/foxnio

# Database pool size
DATABASE_MAX_CONNECTIONS=10

# =============================================================================
# REDIS SETTINGS
# =============================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Redis pool size
REDIS_MAX_CONNECTIONS=10

# =============================================================================
# JWT SETTINGS
# =============================================================================

# JWT secret key for token signing
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here

# JWT expiration time in seconds (default: 7 days)
JWT_EXPIRATION=604800

# Refresh token expiration in seconds (default: 30 days)
REFRESH_TOKEN_EXPIRATION=2592000

# =============================================================================
# OAUTH SETTINGS (Optional)
# =============================================================================

# Anthropic OAuth
ANTHROPIC_CLIENT_ID=
ANTHROPIC_CLIENT_SECRET=

# OpenAI OAuth
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=

# Google/Gemini OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# EMAIL SETTINGS (SMTP)
# =============================================================================

# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email sender address
EMAIL_FROM=noreply@foxnio.io

# =============================================================================
# LOGGING
# =============================================================================

# Log level (trace, debug, info, warn, error)
RUST_LOG=foxnio=info,tower_http=debug

# =============================================================================
# RATE LIMITING
# =============================================================================

# Default rate limit (requests per minute)
DEFAULT_RATE_LIMIT=60

# Burst size
RATE_LIMIT_BURST=10

# =============================================================================
# ADMIN SETTINGS
# =============================================================================

# Initial admin email (for first setup)
ADMIN_EMAIL=admin@example.com

# Initial admin password (will be hashed on first run)
ADMIN_PASSWORD=

# =============================================================================
# SECURITY
# =============================================================================

# Enable TOTP two-factor authentication
ENABLE_TOTP=true

# Session timeout in seconds (default: 24 hours)
SESSION_TIMEOUT=86400

# Max login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in seconds (default: 30 minutes)
LOCKOUT_DURATION=1800
